# ─────────────────────────────────────────────────────────────
# STMS — Environment Variables (monorepo)
#
# Each app reads its own .env.local:
#   apps/web/.env.local   (Next.js)
#   apps/api/.env.local   (Fastify API)
#
# This file is just a reference of the variables each app expects.
# ─────────────────────────────────────────────────────────────

# ── apps/web/.env.local ──────────────────────────────────────
# NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
# API_URL=http://localhost:8080

# ── apps/api/.env.local ──────────────────────────────────────
# PORT=8080
# NODE_ENV=development
# LOG_LEVEL=info
# CORS_ORIGINS=http://localhost:3000
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_ANON_KEY=<anon-key>
# SUPABASE_SERVICE_ROLE_KEY=<service-role-key>   # optional, only needed by admin/cron paths

# ── Supabase secrets (set via `npx supabase secrets set`, NOT .env) ──
# GEMINI_API_KEY=<your-key>
