# ─────────────────────────────────────────────────────────────
# MERA — Environment Variables
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to source control.
# ─────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Service role key — used only by Server Actions and Edge Functions.
# Keep this secret. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ── AI (required for KB and resolution embeddings) ────────────
# Get a key at: https://aistudio.google.com/apikey
# Set this as a Supabase secret (NOT an env var in the app):
#   npx supabase secrets set GEMINI_API_KEY=<your-key>
#
# The Edge Functions read it from their Deno runtime; the Next.js
# app never calls Gemini directly.
#
# GEMINI_API_KEY is intentionally NOT listed here.

# ── pg_net webhook configuration (Supabase SQL editor) ────────
# After running the initial migration, tell the DB how to reach
# your Edge Functions by running these two statements once:
#
#   ALTER DATABASE postgres
#     SET app.supabase_url = 'https://<your-project-ref>.supabase.co';
#
#   ALTER DATABASE postgres
#     SET app.supabase_anon_key = '<your-anon-key>';
#
# These configure the triggers that call embed-resolution and
# ingest-document after ticket closes and document uploads.
