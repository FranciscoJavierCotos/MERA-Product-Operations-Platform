# Test environment variables for apps/api integration tests.
#
# SETUP:
#   1. Start local Supabase:  supabase start
#   2. Get the values:        supabase status
#   3. Copy this file:        cp .env.test.example .env.test
#   4. Paste the values below from the `supabase status` output.
#
# .env.test is gitignored — never commit it.
# .env.test.local is also gitignored and overrides .env.test (for per-machine tweaks).
#
# In CI these are set automatically from `supabase status -o env >> $GITHUB_ENV`.

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=<paste anon key from: supabase status>
SUPABASE_SERVICE_ROLE_KEY=<paste service_role key from: supabase status>
