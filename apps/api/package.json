{
  "name": "api",
  "version": "0.7.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "echo 'no lint configured yet'",
