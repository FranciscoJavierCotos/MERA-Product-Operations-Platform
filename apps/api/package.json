    "@stms/contracts": "workspace:*",
    "@supabase/supabase-js": "^2.43.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.1.0",
    "fastify-plugin": "^5.0.1",
    "fastify-type-provider-zod": "^4.0.2",
    "pino-pretty": "^11.3.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.0.0",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.0.0",
